# Railway & Local Development Configuration
# Copy this file to .env for local development customization

# Server port (optional, defaults to 3000)
PORT=3000

# Database path (optional, defaults to ./database.sqlite)
# For Railway, use /tmp/database.sqlite or leave unset
DB_PATH=/tmp/database.sqlite

# Admin password (optional, defaults to admin@2026)
# ADMIN_PASSWORD=admin@2026
